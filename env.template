# Support Bot Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =====================================
# REQUIRED - MongoDB Atlas Configuration
# =====================================
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourApp
DATABASE_NAME=support_bot
COLLECTION_NAME=knowledge_base

# =====================================
# REQUIRED - MongoDB Atlas API Configuration  
# =====================================
ATLAS_PUBLIC_KEY=your_atlas_public_key_here
ATLAS_PRIVATE_KEY=your_atlas_private_key_here
ATLAS_BASE_URL=https://cloud.mongodb.com/api/atlas/v1.0

# =====================================
# REQUIRED - Voyage AI Configuration
# =====================================
VOYAGE_API_KEY=your_voyage_ai_api_key_here
VOYAGE_MODEL=voyage-3-large

# =====================================
# OPTIONAL - Application Configuration
# =====================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
DEBUG=true

# =====================================
# OPTIONAL - Vector Search Configuration
# =====================================
VECTOR_INDEX_NAME=vector_index
SEARCH_INDEX_NAME=search_index

# =====================================
# OPTIONAL - Chunking Configuration
# =====================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =====================================
# USAGE INSTRUCTIONS:
# =====================================
# 1. Copy this file to .env: cp env.template .env
# 2. Fill in the REQUIRED values above with your actual credentials
# 3. Optionally modify the OPTIONAL values if needed
# 4. The .env file is already in .gitignore and won't be committed to git
#
# Where to get the required values:
# - MONGODB_URI: From MongoDB Atlas connection string
# - ATLAS_PUBLIC_KEY & ATLAS_PRIVATE_KEY: From MongoDB Atlas API Keys section
# - VOYAGE_API_KEY: From your Voyage AI account
